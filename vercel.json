{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install --include=dev",
  "buildCommand": "npm run build",
  "outputDirectory": "react-stream-ai-assistant/dist",
  "functions": {
    "api/public-config.ts": {
      "maxDuration": 10
    },
    "api/token.ts": {
      "maxDuration": 10
    },
    "api/index.ts": {
      "maxDuration": 60,
      "includeFiles": "nodejs-ai-assistant/dist/**"
    }
  },
  "rewrites": [
    { "source": "/api/webhook", "destination": "/api" },
    { "source": "/api/start-ai-agent", "destination": "/api" },
    { "source": "/api/stop-ai-agent", "destination": "/api" },
    { "source": "/api/set-persona", "destination": "/api" },
    { "source": "/api/agent-status", "destination": "/api" },
    { "source": "/api/personas", "destination": "/api" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
