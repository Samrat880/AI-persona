{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install --include=dev",
  "buildCommand": "npm run build",
  "outputDirectory": "react-stream-ai-assistant/dist",
  "functions": {
    "api/public-config.ts": {
      "maxDuration": 10
    },
    "api/token.ts": {
      "maxDuration": 10
    },
    "api/agent-status.ts": {
      "maxDuration": 15,
      "includeFiles": "nodejs-ai-assistant/dist/**"
    },
    "api/personas.ts": {
      "maxDuration": 10,
      "includeFiles": "nodejs-ai-assistant/dist/**"
    },
    "api/set-persona.ts": {
      "maxDuration": 15,
      "includeFiles": "nodejs-ai-assistant/dist/**"
    },
    "api/stop-ai-agent.ts": {
      "maxDuration": 15,
      "includeFiles": "nodejs-ai-assistant/dist/**"
    },
    "api/start-ai-agent.ts": {
      "maxDuration": 60,
      "includeFiles": "nodejs-ai-assistant/dist/**"
    },
    "api/index.ts": {
      "maxDuration": 60,
      "includeFiles": "nodejs-ai-assistant/dist/**"
    }
  },
  "rewrites": [
    { "source": "/api/webhook", "destination": "/api" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
