# Stream Chat (required)
STREAM_API_KEY=your_stream_api_key
STREAM_API_SECRET=your_stream_api_secret

# OpenAI (required)
OPENAI_API_KEY=your_openai_api_key

# Optional: web search via Tavily
TAVILY_API_KEY=

# Optional: YouTube video search for guru channels
YOUTUBE_API_KEY=

# Optional: used for persona avatar URLs in Stream bot profiles
FRONTEND_URL=http://localhost:3000

# Landing: editorial = poster style | default or remove to backout
# NEXT_PUBLIC_LANDING_VARIANT=editorial
